// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Review {
  id               String   @id @default(cuid())
  shop             String
  shopifyProductId String?
  productTitle     String
  customerName     String
  customerEmail    String?
  rating           Int
  title            String?
  body             String
  status           String   @default("pending")
  imageUrl         String?
  source           String?
  importId         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([shop])
  @@index([shop, status])
  @@index([shop, importId])
}

model ImportRecord {
  id        String   @id @default(cuid())
  shop      String
  filename  String
  totalRows Int
  succeeded Int
  failed    Int
  status    String
  createdAt DateTime @default(now())

  @@index([shop])
}

model WidgetConfig {
  shop  String  @id

  // Main Widget
  mainTitle               String  @default("Reviews")
  mainShowWriteButton     Boolean @default(true)
  mainShowBreakdown       Boolean @default(true)
  mainShowWithPhotosFilter Boolean @default(true)
  mainDefaultSort         String  @default("latest")
  mainPageSize            Int     @default(20)
  mainAccentColor         String  @default("#111111")

  // Fan Carousel
  fanTitle          String  @default("From our customers")
  fanShowRating     Boolean @default(true)
  fanShowName       Boolean @default(true)
  fanShowBadge      Boolean @default(true)
  fanAccentColor    String  @default("#ffffff")

  // Card Carousel
  cardTitle         String  @default("What our customers say")
  cardShowRating    Boolean @default(true)
  cardShowName      Boolean @default(true)
  cardShowBadge     Boolean @default(true)
  cardShowProduct   Boolean @default(true)
  cardMaxChars      Int     @default(120)
  cardAccentColor   String  @default("#000000")

  updatedAt DateTime @updatedAt
}

model ShopSettings {
  shop             String   @id
  embedActivated   Boolean  @default(false)
  reviewsImported  Boolean  @default(false)
  confirmedWorking Boolean  @default(false)
  autoPublish      Boolean  @default(false)
  widgetEnabled    Boolean  @default(true)
  plan             String   @default("free")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
