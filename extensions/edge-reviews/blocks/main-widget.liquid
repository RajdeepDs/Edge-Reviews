  "name": "ER: Main Widget",
  "target": "section",
  "settings": [
    {
      "type": "range",
      "id": "reviews_per_page",
      "label": "Reviews per page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_photos",
      "label": "Show review photos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "require_photo",
      "label": "Require photo in form",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_email_field",
      "label": "Show email field in form",
      "default": true
    }
  ]
}
{% endschema %}
