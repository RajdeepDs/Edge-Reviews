{%- comment -%}
  Edge Reviews — Main widget
  Block settings = placement-level overrides only.
  All other config (colors, toggles, sort, page size) is managed in the Edge Reviews admin app
  and served via the widget API endpoint.
{%- endcomment -%}

{%- assign er_shop = shop.permanent_domain | default: shop.domain -%}
{%- assign er_shop_param = er_shop | url_encode -%}
{%- assign er_endpoint = '/apps/edge-reviews/widget?shop=' | append: er_shop_param -%}
{%- assign er_submit = '/apps/edge-reviews/reviews?shop=' | append: er_shop_param -%}

{%- assign er_product_id = '' -%}
{%- assign er_product_title = '' -%}
{%- if product -%}
  {%- assign er_product_id = product.id -%}
  {%- assign er_product_title = product.title -%}
{%- endif -%}

<script>
  (function () {
    if (window.__edgeReviewsAssetsLoaded) return;
    window.__edgeReviewsAssetsLoaded = true;

    var cssHref = {{ 'edge-reviews.css' | asset_url | json }};
    var jsSrc = {{ 'edge-reviews.js' | asset_url | json }};

    if (!document.querySelector('link[href="' + cssHref + '"]')) {
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = cssHref;
      document.head.appendChild(link);
    }

    if (!document.querySelector('script[src="' + jsSrc + '"]')) {
      var s = document.createElement('script');
      s.src = jsSrc;
      s.defer = true;
      document.head.appendChild(s);
    }
  })();
</script>

<section class="er-root" data-er-widget="main"
  data-er-shop="{{ er_shop }}"
  data-er-endpoint="{{ er_endpoint }}"
  data-er-submit="{{ er_submit }}"
  data-er-product-id="{{ er_product_id }}"
  data-er-product-title="{{ er_product_title | escape }}"
></section>

{% schema %}
{
  "name": "t:blocks.main_widget.name",
  "target": "section",
  "settings": []
}
{% endschema %}
