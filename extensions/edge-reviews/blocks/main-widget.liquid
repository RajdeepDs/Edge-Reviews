{%- comment -%}
  Edge Reviews — Main widget
  This block renders a lightweight shell and a JS mount point.
{%- endcomment -%}

{%- assign er_shop = shop.permanent_domain | default: shop.domain -%}
{%- assign er_shop_param = er_shop | url_encode -%}
{%- comment -%}
  App proxy config maps:
    /apps/edge-reviews/<path>  ->  <application_url>/api/<path>
  Since our backend routes are /api/widget and /api/reviews, the proxy path should be:
    /apps/edge-reviews/widget  and  /apps/edge-reviews/reviews
{%- endcomment -%}
{%- assign er_endpoint = '/apps/edge-reviews/widget?shop=' | append: er_shop_param -%}
{%- assign er_submit = '/apps/edge-reviews/reviews?shop=' | append: er_shop_param -%}

{%- assign er_product_id = '' -%}
{%- assign er_product_title = '' -%}
{%- if product -%}
  {%- assign er_product_id = product.id -%}
  {%- assign er_product_title = product.title -%}
{%- endif -%}

<script>
  (function () {
    if (window.__edgeReviewsAssetsLoaded) return;
    window.__edgeReviewsAssetsLoaded = true;

    var cssHref = {{ 'edge-reviews.css' | asset_url | json }};
    var jsSrc = {{ 'edge-reviews.js' | asset_url | json }};

    if (!document.querySelector('link[href="' + cssHref + '"]')) {
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = cssHref;
      document.head.appendChild(link);
    }

    if (!document.querySelector('script[src="' + jsSrc + '"]')) {
      var s = document.createElement('script');
      s.src = jsSrc;
      s.defer = true;
      document.head.appendChild(s);
    }
  })();
</script>

<section class="er-root" data-er-widget="main"
  data-er-shop="{{ er_shop }}"
  data-er-endpoint="{{ er_endpoint }}"
  data-er-submit="{{ er_submit }}"
  data-er-product-id="{{ er_product_id }}"
  data-er-product-title="{{ er_product_title | escape }}"
  data-er-title-override="{{ block.settings.title | escape }}"
  data-er-accent="{{ block.settings.accent_color }}"
  data-er-show-breakdown="{{ block.settings.show_breakdown }}"
  data-er-show-write="{{ block.settings.show_write_button }}"
  data-er-default-sort="{{ block.settings.default_sort }}"
  data-er-page-size="{{ block.settings.page_size }}"
>
  <div class="er-widget er-widget--main" style="--er-accent: {{ block.settings.accent_color }};">
    <div class="er-shell">
      <div class="er-shell__header">
        <div class="er-shell__title"></div>
        <div class="er-shell__meta">
          <div class="er-skel er-skel--stars"></div>
          <div class="er-skel er-skel--text"></div>
        </div>
      </div>
      <div class="er-shell__grid">
        {%- for i in (1..8) -%}
          <div class="er-card er-card--skeleton" aria-hidden="true">
            <div class="er-skel er-skel--media"></div>
            <div class="er-card__body">
              <div class="er-skel er-skel--line"></div>
              <div class="er-skel er-skel--line er-skel--lineShort"></div>
              <div class="er-skel er-skel--starsSmall"></div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:blocks.main_widget.name",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:blocks.main_widget.settings.title",
      "default": "Reviews"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "t:blocks.main_widget.settings.accent_color",
      "default": "#111111"
    },
    {
      "type": "checkbox",
      "id": "show_breakdown",
      "label": "t:blocks.main_widget.settings.show_breakdown",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_write_button",
      "label": "t:blocks.main_widget.settings.show_write_button",
      "default": true
    },
    {
      "type": "select",
      "id": "default_sort",
      "label": "t:blocks.main_widget.settings.default_sort",
      "default": "latest",
      "options": [
        { "value": "latest", "label": "Latest" },
        { "value": "highest", "label": "Highest rating" },
        { "value": "lowest", "label": "Lowest rating" }
      ]
    },
    {
      "type": "range",
      "id": "page_size",
      "min": 4,
      "max": 48,
      "step": 4,
      "unit": "rev",
      "label": "t:blocks.main_widget.settings.page_size",
      "default": 20
    }
  ]
}
{% endschema %}

