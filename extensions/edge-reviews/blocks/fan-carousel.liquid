{%- comment -%}
  Edge Reviews — Fan carousel (image fan / centered hero)
{%- endcomment -%}

{%- assign er_shop = shop.permanent_domain | default: shop.domain -%}
{%- assign er_shop_param = er_shop | url_encode -%}
{%- assign er_endpoint = '/apps/edge-reviews/widget?shop=' | append: er_shop_param -%}

<script>
  (function () {
    if (window.__edgeReviewsAssetsLoaded) return;
    window.__edgeReviewsAssetsLoaded = true;

    var cssHref = {{ 'edge-reviews.css' | asset_url | json }};
    var jsSrc = {{ 'edge-reviews.js' | asset_url | json }};

    if (!document.querySelector('link[href="' + cssHref + '"]')) {
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = cssHref;
      document.head.appendChild(link);
    }

    if (!document.querySelector('script[src="' + jsSrc + '"]')) {
      var s = document.createElement('script');
      s.src = jsSrc;
      s.defer = true;
      document.head.appendChild(s);
    }
  })();
</script>

<section
  class="er-root"
  data-er-widget="fan"
  data-er-shop="{{ er_shop }}"
  data-er-endpoint="{{ er_endpoint }}"
  data-er-title-override="{{ block.settings.title | escape }}"
  data-er-accent="{{ block.settings.accent_color }}"
  data-er-show-rating="{{ block.settings.show_rating }}"
  data-er-show-name="{{ block.settings.show_name }}"
  data-er-show-badge="{{ block.settings.show_badge }}"
>
  <div class="er-widget er-widget--fan" style="--er-accent: {{ block.settings.accent_color }};">
    <div class="er-shell">
      <div class="er-shell__header er-shell__header--center">
        <div class="er-shell__title"></div>
        <div class="er-shell__meta">
          <div class="er-skel er-skel--stars"></div>
          <div class="er-skel er-skel--text"></div>
        </div>
      </div>
      <div class="er-fan__shell">
        <div class="er-skel er-skel--pill" style="width:36px;height:36px;border-radius:999px;"></div>
        <div class="er-fan__skeletonRow">
          {%- for i in (1..3) -%}
            <div class="er-skel er-skel--fanCard"></div>
          {%- endfor -%}
        </div>
        <div class="er-skel er-skel--pill" style="width:36px;height:36px;border-radius:999px;"></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:blocks.fan_carousel.name",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:blocks.fan_carousel.settings.title",
      "default": "Real customer stories"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "t:blocks.fan_carousel.settings.accent_color",
      "default": "#111111"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "t:blocks.fan_carousel.settings.show_rating",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_name",
      "label": "t:blocks.fan_carousel.settings.show_name",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "t:blocks.fan_carousel.settings.show_badge",
      "default": true
    }
  ]
}
{% endschema %}

